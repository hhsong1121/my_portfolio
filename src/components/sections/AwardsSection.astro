---
/**
 * Awards & Academics Section
 * ── 수상 이력 및 학회 발표: 타임라인 형태 ──
 */
import { getCollection } from 'astro:content';
import Icon from '../icons/Icon.astro';

const awards = (await getCollection('awards')).sort((a, b) => a.data.order - b.data.order);
---

<section id="awards" class="border-y border-navy-100 bg-white py-16 sm:py-20">
	<div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
		<div class="mb-10 flex items-center gap-3">
			<div class="flex h-10 w-10 items-center justify-center rounded-xl bg-navy-800 text-white">
				<Icon name="award" class="h-5 w-5" />
			</div>
			<div>
				<h2 class="text-2xl font-bold tracking-tight text-navy-950 sm:text-3xl">
					Awards &amp; Academics
				</h2>
				<p class="text-sm text-ink-muted">Conference presentations and academic achievements</p>
			</div>
		</div>

		<div class="relative space-y-0">
			<div
				class="absolute left-[1.125rem] top-2 bottom-2 w-0.5 bg-navy-200 sm:left-5"
				aria-hidden="true"
			/>

			{
				awards.map((award) => {
					const isOral = award.data.presentationType.toLowerCase().includes('oral');
					const iconName = isOral ? 'mic' : 'presentation';
					return (
						<div class="relative flex gap-5 pb-8 last:pb-0 sm:gap-6">
							<div class="relative z-10 flex h-9 w-9 shrink-0 items-center justify-center rounded-full border-2 border-navy-300 bg-white sm:h-10 sm:w-10">
								<Icon name={iconName} class="h-4 w-4 text-navy-700" />
							</div>

							<div class="min-w-0 flex-1 rounded-xl border border-navy-100 bg-surface p-5 shadow-sm">
								<div class="flex flex-wrap items-center gap-2">
									<span class="rounded-full bg-navy-800 px-3 py-0.5 text-xs font-bold text-white">
										{award.data.date}
									</span>
									<span class="rounded-full border border-navy-200 bg-white px-3 py-0.5 text-xs font-medium text-navy-700">
										{award.data.presentationType}
									</span>
								</div>
								<p class="mt-3 text-sm font-semibold text-navy-800">{award.data.event}</p>
								<h3 class="mt-1 text-base font-medium leading-snug text-ink sm:text-lg">
									{award.data.title}
								</h3>
							</div>
						</div>
					);
				})
			}
		</div>
	</div>
</section>
