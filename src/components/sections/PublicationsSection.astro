---
/**
 * Publications Section
 * ── 출판된 논문: Content Collection 기반 카드 리스트 ──
 */
import { getCollection } from 'astro:content';
import Icon from '../icons/Icon.astro';

const publications = (await getCollection('publications')).sort(
	(a, b) => a.data.order - b.data.order,
);
---

<section id="publications" class="bg-surface py-16 sm:py-20">
	<div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
		<div class="mb-10 flex items-center gap-3">
			<div class="flex h-10 w-10 items-center justify-center rounded-xl bg-navy-800 text-white">
				<Icon name="book-open" class="h-5 w-5" />
			</div>
			<div>
				<h2 class="text-2xl font-bold tracking-tight text-navy-950 sm:text-3xl">Publications</h2>
				<p class="text-sm text-ink-muted">Peer-reviewed research and scholarly articles</p>
			</div>
		</div>

		<div class="space-y-4">
			{
				publications.map((pub) => (
					<article class="group rounded-xl border border-navy-100 bg-white p-5 shadow-sm transition-shadow hover:shadow-md sm:p-6">
						<h3 class="text-base font-semibold leading-snug text-navy-900 group-hover:text-navy-700 sm:text-lg">
							{pub.data.title}
						</h3>
						<p class="mt-2 text-sm text-ink-muted">
							<span class="font-medium text-ink">{pub.data.authors}</span>
						</p>
						<div class="mt-3 flex flex-wrap items-center gap-3">
							<span class="rounded-full bg-navy-50 px-3 py-1 text-xs font-semibold text-navy-700">
								{pub.data.journal} ({pub.data.year})
							</span>
							{pub.data.doi && (
								<span class="text-xs text-navy-500">DOI: {pub.data.doi}</span>
							)}
							{pub.data.link && (
								<a
									href={pub.data.link}
									target="_blank"
									rel="noopener noreferrer"
									class="inline-flex items-center gap-1 text-xs font-medium text-navy-600 hover:text-navy-800"
								>
									<Icon name="external-link" class="h-3 w-3" />
									View paper
								</a>
							)}
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>
