---
/**
 * Projects Section
 * ── AI 및 Computer Engineering 프로젝트: 그리드 카드 + 모달 상세 ──
 */
import { getCollection, render } from 'astro:content';
import Icon from '../icons/Icon.astro';

const projectEntries = (await getCollection('projects')).sort(
	(a, b) => a.data.order - b.data.order,
);

const renderedProjects = await Promise.all(
	projectEntries.map(async (entry) => {
		const { Content } = await render(entry);
		return { entry, Content };
	}),
);

const projectIds = renderedProjects.map(({ entry }) => entry.id);
---

<section id="projects" class="bg-surface py-16 sm:py-20">
	<div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
		<div class="mb-10 flex items-center gap-3">
			<div class="flex h-10 w-10 items-center justify-center rounded-xl bg-navy-800 text-white">
				<Icon name="folder-kanban" class="h-5 w-5" />
			</div>
			<div>
				<h2 class="text-2xl font-bold tracking-tight text-navy-950 sm:text-3xl">Projects</h2>
				<p class="text-sm text-ink-muted">AI and computer engineering research projects</p>
			</div>
		</div>

		<!-- 프로젝트 그리드 카드 -->
		<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{
				renderedProjects.map(({ entry }) => (
					<button
						type="button"
						data-project-id={entry.id}
						class="group cursor-pointer overflow-hidden rounded-2xl border border-navy-100 bg-white text-left shadow-sm transition-all hover:-translate-y-1 hover:border-navy-200 hover:shadow-lg"
					>
						<div class="p-5">
							<h3 class="font-semibold text-navy-900 group-hover:text-navy-700">
								{entry.data.title}
							</h3>
							<p class="mt-2 line-clamp-2 text-sm text-ink-muted">{entry.data.description}</p>
							<div class="mt-3 flex flex-wrap gap-1.5">
								{entry.data.tags.map((tag) => (
									<span class="rounded-full bg-navy-50 px-2.5 py-0.5 text-xs font-medium text-navy-700">
										{tag}
									</span>
								))}
							</div>
						</div>
					</button>
				))
			}
		</div>
	</div>

	<!-- 프로젝트 상세 모달 -->
	<div
		id="project-modal"
		class="fixed inset-0 z-[100] hidden"
		role="dialog"
		aria-modal="true"
	>
		<div
			id="project-modal-overlay"
			class="absolute inset-0 bg-navy-950/60 backdrop-blur-sm"
			aria-hidden="true"
		/>

		<div class="relative flex h-full items-center justify-center p-4 sm:p-6">
			<div class="relative max-h-[90vh] w-full max-w-3xl overflow-y-auto rounded-2xl bg-white shadow-2xl">
				<button
					id="project-modal-close"
					type="button"
					class="absolute right-4 top-4 z-10 rounded-full bg-navy-100 p-2 text-navy-700 transition-colors hover:bg-navy-200"
					aria-label="Close project details"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
				</button>

				{
					renderedProjects.map(({ entry, Content }) => (
						<div data-project-panel={entry.id} class="hidden">
							<div class="p-6 sm:p-8">
								<h2 class="pr-10 text-2xl font-bold text-navy-950">{entry.data.title}</h2>
								<p class="mt-2 text-sm text-ink-muted">{entry.data.description}</p>
								<div class="mt-4 flex flex-wrap gap-2">
									{entry.data.tags.map((tag) => (
										<span class="rounded-full border border-navy-200 bg-navy-50 px-3 py-1 text-xs font-medium text-navy-800">
											{tag}
										</span>
									))}
								</div>
								<div class="project-content mt-6 max-w-none text-ink">
									<Content />
								</div>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>

<style>
	/* 프로젝트 모달 내 마크다운 스타일 */
	.project-content :global(h2) {
		margin-top: 1.5rem;
		margin-bottom: 0.75rem;
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--color-navy-900);
	}
	.project-content :global(h3) {
		margin-top: 1rem;
		margin-bottom: 0.5rem;
		font-size: 1.125rem;
		font-weight: 500;
		color: var(--color-navy-800);
	}
	.project-content :global(p) {
		margin-bottom: 0.75rem;
		line-height: 1.625;
		color: var(--color-ink-muted);
	}
	.project-content :global(ul) {
		margin-bottom: 1rem;
		list-style-type: disc;
		padding-left: 1.25rem;
	}
	.project-content :global(li) {
		color: var(--color-ink-muted);
		margin-bottom: 0.25rem;
	}
	.project-content :global(pre) {
		margin-bottom: 1rem;
		overflow-x: auto;
		border-radius: 0.5rem;
		background-color: var(--color-navy-950);
		padding: 1rem;
		font-size: 0.875rem;
		color: var(--color-navy-100);
	}
	.project-content :global(code) {
		border-radius: 0.25rem;
		background-color: var(--color-navy-50);
		padding: 0.125rem 0.375rem;
		font-size: 0.875rem;
		color: var(--color-navy-800);
	}
	.project-content :global(pre code) {
		background-color: transparent;
		padding: 0;
		color: var(--color-navy-100);
	}
</style>

<script>
	/** 프로젝트 카드 클릭 → 모달 열기/닫기 */
	const modal = document.getElementById('project-modal');
	const overlay = document.getElementById('project-modal-overlay');
	const closeBtn = document.getElementById('project-modal-close');
	const panels = document.querySelectorAll<HTMLElement>('[data-project-panel]');
	const cards = document.querySelectorAll<HTMLElement>('[data-project-id]');

	function openModal(projectId: string) {
		panels.forEach((panel) => {
			panel.classList.toggle('hidden', panel.dataset.projectPanel !== projectId);
		});
		modal?.classList.remove('hidden');
		document.body.style.overflow = 'hidden';
	}

	function closeModal() {
		modal?.classList.add('hidden');
		document.body.style.overflow = '';
	}

	cards.forEach((card) => {
		card.addEventListener('click', () => {
			const id = card.dataset.projectId;
			if (id) openModal(id);
		});
	});

	closeBtn?.addEventListener('click', closeModal);
	overlay?.addEventListener('click', closeModal);

	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') closeModal();
	});
</script>
