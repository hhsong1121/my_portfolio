---
/**
 * Skills Section
 * ── 시각적 스킬 스택: AI & Engineering / Clinical Data Analysis ──
 */
import Icon from '../icons/Icon.astro';

const skillCategories = [
	{
		title: 'AI & Engineering',
		icon: 'brain' as const,
		skills: ['Python', 'R', 'SQL', 'MONAI', 'sLM', 'RAG'],
		accent: 'bg-navy-800 text-white',
		badge: 'border-navy-200 bg-navy-50 text-navy-800',
	},
	{
		title: 'Clinical Data Analysis',
		icon: 'bar-chart' as const,
		skills: ['Biostatistics', 'PSM', 'Survival Analysis'],
		accent: 'bg-navy-700 text-white',
		badge: 'border-navy-200 bg-white text-navy-800',
	},
];
---

<section id="skills" class="border-y border-navy-100 bg-white py-16 sm:py-20">
	<div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
		<div class="mb-10 text-center">
			<h2 class="text-2xl font-bold tracking-tight text-navy-950 sm:text-3xl">Skills</h2>
			<p class="mt-2 text-sm text-ink-muted">Technical expertise across AI engineering and clinical analytics</p>
		</div>

		<div class="grid gap-8 sm:grid-cols-2">
			{
				skillCategories.map((category) => (
					<div class="rounded-2xl border border-navy-100 bg-surface p-6 shadow-sm">
						<div class="mb-5 flex items-center gap-3">
							<div class={`flex h-10 w-10 items-center justify-center rounded-xl ${category.accent}`}>
								<Icon name={category.icon} class="h-5 w-5" />
							</div>
							<h3 class="text-lg font-semibold text-navy-900">{category.title}</h3>
						</div>
						<div class="flex flex-wrap gap-2">
							{category.skills.map((skill) => (
								<span
									class={`rounded-full border px-3.5 py-1.5 text-sm font-medium ${category.badge}`}
								>
									{skill}
								</span>
							))}
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>
