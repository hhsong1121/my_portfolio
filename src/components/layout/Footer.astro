---
/**
 * Contact & Links Footer
 * ── 푸터: 이메일, GitHub, PubMed, ORCID, Google Scholar ──
 */
import Icon from '../icons/Icon.astro';

const contactLinks = [
	{ label: 'Email', href: 'mailto:hyeonghunsong1121@gmail.com', icon: 'mail' as const },
	{ label: 'GitHub', href: 'https://github.com/hhsong1121', icon: 'github' as const },
];

const academicLinks = [
	{ label: 'PubMed', href: 'https://pubmed.ncbi.nlm.nih.gov/?term=Song+Hyeonghun' },
	{ label: 'ORCID', href: 'https://orcid.org/0000-0000-0000-0000' },
	{ label: 'Google Scholar', href: 'https://scholar.google.com/citations?user=PLACEHOLDER' },
];
---

<footer id="contact" class="border-t border-navy-100 bg-navy-950 text-navy-100">
	<div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
		<div class="flex flex-col items-center gap-8 text-center">
			<div>
				<h2 class="text-lg font-semibold text-white">Contact & Links</h2>
				<p class="mt-2 text-sm text-navy-300">
					Feel free to reach out for research collaboration or inquiries.
				</p>
			</div>

			<!-- 이메일 & GitHub -->
			<div class="flex flex-wrap items-center justify-center gap-4">
				{
					contactLinks.map((link) => (
						<a
							href={link.href}
							target={link.href.startsWith('mailto') ? undefined : '_blank'}
							rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
							class="inline-flex items-center gap-2 rounded-full border border-navy-700 bg-navy-900 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:border-navy-500 hover:bg-navy-800"
						>
							<Icon name={link.icon} class="h-4 w-4" />
							{link.label}
						</a>
					))
				}
			</div>

			<!-- 학술 프로필 링크 -->
			<div class="flex flex-wrap items-center justify-center gap-3">
				{
					academicLinks.map((link) => (
						<a
							href={link.href}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-1.5 rounded-lg bg-navy-800 px-4 py-2 text-sm font-medium text-navy-100 transition-colors hover:bg-navy-700 hover:text-white"
						>
							<Icon name="external-link" class="h-3.5 w-3.5" />
							{link.label}
						</a>
					))
				}
			</div>

			<p class="text-xs text-navy-500">
				&copy; {new Date().getFullYear()} Hyeonghun Song. All rights reserved.
			</p>
		</div>
	</div>
</footer>
